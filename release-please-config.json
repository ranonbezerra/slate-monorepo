{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "tag-separator": "/",
  "packages": {
    "packages/api": {
      "release-type": "python",
      "component": "api",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/web/shared": {
      "release-type": "node",
      "component": "web-shared",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/web/app": {
      "release-type": "node",
      "component": "web-app",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/web/backoffice": {
      "release-type": "node",
      "component": "web-backoffice",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
