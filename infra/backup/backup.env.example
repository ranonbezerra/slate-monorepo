# Slate backup — environment for the systemd service.
# Copy to /etc/slate/backup.env and fill in. chmod 600 it.

POSTGRES_USER=slate
POSTGRES_DB=slate
PG_CONTAINER=dl-postgres
BACKUP_DIR=/var/backups/slate
RETENTION_DAYS=14

# Off-host target (STRONGLY recommended — a single-VPS local backup dies with the
# disk). Configure an rclone remote first: `rclone config` (S3 / Cloudflare R2 /
# Backblaze B2). Leave empty to keep backups local-only (NOT recommended).
RCLONE_REMOTE=
