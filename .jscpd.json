{
  "threshold": 5,
  "reporters": ["console"],
  "minLines": 10,
  "minTokens": 50,
  "path": [
    "packages/api/src",
    "packages/web/shared/src",
    "packages/web/app/src",
    "packages/web/backoffice/src"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.venv/**",
    "**/*.lock",
    "**/build/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/tests/**"
  ],
  "absolute": true
}
