# ─────────────────────────────────────────────
# DailyLoadout — Root (Infrastructure)
# Used by docker-compose only.
# Copy to .env and adjust as needed.
# ─────────────────────────────────────────────

# Ports (host-side mapping — LOOPBACK ONLY in dev via the override file)
POSTGRES_PORT=5433
REDIS_PORT=6380
OLLAMA_PORT=11434
SEARXNG_PORT=8888

# Postgres credentials
# PRODUCTION: POSTGRES_PASSWORD is REQUIRED (compose refuses to start without
# it). Generate a strong value; never ship the dev default "dailyloadout".
POSTGRES_USER=dailyloadout
POSTGRES_PASSWORD=dailyloadout
POSTGRES_DB=dailyloadout

# Redis auth
# PRODUCTION: REDIS_PASSWORD is REQUIRED (compose refuses to start without it).
# The app's REDIS_URL must include this password (redis://:<pw>@redis:6379/0).
REDIS_PASSWORD=devredispassword
