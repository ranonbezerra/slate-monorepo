# ─────────────────────────────────────────────
# Slate — .gitignore
# ─────────────────────────────────────────────

# Environment
.env
.env.local
.env.*.local

# Local brand
branding/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code (personal settings — team settings.json is committed)
.claude/settings.local.json

# ─────────────────────────────────────────────
# Python (packages/api)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# ─────────────────────────────────────────────
# Flutter (packages/mobile)
# Detailed rules in packages/mobile/.gitignore; these repo-wide guards also
# catch stray artifacts if an old-layout branch (packages/app) is checked out.
# ─────────────────────────────────────────────
.fvm/
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
*.iml
**/.metadata
**/ios/Flutter/ephemeral/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.*
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java

# ─────────────────────────────────────────────
# Node / Bun (packages/web)
# ─────────────────────────────────────────────
node_modules/
packages/web/dist/

# ─────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────
# Uploads / local storage
# ─────────────────────────────────────────────
uploads/
*.sqlite3

# ─────────────────────────────────────────────
# Security audit reports (generated by make audit)
# ─────────────────────────────────────────────
audits/reports/
