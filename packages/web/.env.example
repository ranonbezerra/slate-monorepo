# ─────────────────────────────────────────────
# DailyLoadout Web — Environment Variables
# Copy to .env and adjust as needed.
# Only VITE_-prefixed vars are exposed to the browser.
# ─────────────────────────────────────────────

VITE_API_URL=http://localhost:8100
VITE_ENABLE_CONCIERGE=false
# Social login (OAuth) providers shown on the login/register pages.
# Comma-separated; supported: google, twitch. Empty string disables social login.
VITE_OAUTH_PROVIDERS=google,twitch

# Turnstile CAPTCHA
VITE_TURNSTILE_SITE_KEY=
