{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"files": {
		"includes": ["**", "!dist", "!coverage"]
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 99
	},
	"linter": {
		"rules": {
			"preset": "recommended"
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
