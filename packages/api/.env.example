# ─────────────────────────────────────────────
# Slate API — Environment Variables
#
# This file lists ONLY what you set per environment: secrets + env-specific
# config. Every other setting uses its default in src/slate/config.py — to
# override one, just add `KEY=value` here. Copy to .env and adjust.
#
# PRODUCTION (app refuses to boot without these):
#   APP_ENV=production · SECRET_KEY=<real> · AUTH_COOKIE_SECURE=true ·
#   TURNSTILE_SECRET=<real> · DATABASE_URL · REDIS_URL · CORS_ORIGINS
#
# AWS: keys tagged [SECRET] go in Secrets Manager; the rest as ECS task env /
# SSM Parameter Store. Never `KEY=   # comment` on an empty key — python-dotenv
# folds the comment into the value; put the comment on its own line above.
# ─────────────────────────────────────────────

# ── Core ─────────────────────────────────────
APP_ENV=development                # [PROD] "production" (any non-dev value hardens)
SECRET_KEY=change-me-in-prod       # [PROD][SECRET] real 32+ char secret (boot fails on default)
CORS_ORIGINS=["http://localhost:3200","http://localhost:5173","http://localhost:5174"]   # [PROD] your web domain(s)
TRUSTED_HOSTS=["*"]                 # [PROD] your API domain(s), e.g. ["api.exemplo.com"]

# ── Database / Redis — [SECRET: both carry credentials] ─
DATABASE_URL=postgresql+asyncpg://slateapp:slateapp@localhost:5433/slateapp
REDIS_URL=redis://:devredispassword@localhost:6380/0

# ── Auth refresh cookie (web cookie-mode) ────
AUTH_COOKIE_SECURE=false            # [PROD] MUST be true (boot fails if false in prod)
AUTH_COOKIE_SAMESITE=lax            # 'none' if web/api on different domains (requires Secure)
# Set only if web and api share a parent domain:
AUTH_COOKIE_DOMAIN=

# ── CAPTCHA (Cloudflare Turnstile) ───────────
# [PROD][SECRET] REQUIRED (boot fails if empty in prod); empty => CAPTCHA is a no-op.
TURNSTILE_SECRET=

# ── Providers (real vs dummy per environment) ─
LLM_PROVIDER=ollama                 # ollama | dummy
AGENT_PROVIDER=dummy                # [PROD] langgraph | dummy
RESEARCH_PROVIDER=dummy             # [PROD] searxng | dummy
LET_ME_CARRY_PROVIDER=dummy            # [PROD] langgraph | dummy
STT_PROVIDER=dummy                  # [PROD] whisper_local | dummy
OCR_PROVIDER=tesseract              # tesseract | dummy
EMBEDDING_PROVIDER=dummy            # ollama | dummy
# Endpoints for the real (non-dummy) providers:
OLLAMA_BASE_URL=http://localhost:11434
SEARXNG_BASE_URL=http://localhost:8888   # Docker: http://searxng:8080

# ── Social login / OAuth — [SECRET: the *_SECRET keys] ─
# [PROD-FEATURE] leave empty to disable that provider.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TWITCH_OAUTH_CLIENT_ID=
TWITCH_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8100    # [PROD] your API public URL
OAUTH_WEB_SUCCESS_URL=http://localhost:5173/oauth/callback   # [PROD] your web URL
OAUTH_WEB_ERROR_URL=http://localhost:5173/login              # [PROD] your web URL

# ── IGDB (game metadata) — [SECRET: IGDB_CLIENT_SECRET] ─
# [PROD-FEATURE] Twitch app client id/secret; empty => enrichment disabled.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Email (verification / reset / change) — [SECRET: SMTP_PASSWORD] ─
# [PROD-FEATURE] empty SMTP_HOST => no email is sent (dev auto-verifies accounts).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Slate <noreply@slate.local>
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173/verify-email    # [PROD] your web URL
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password      # [PROD] your web URL
EMAIL_CHANGE_BASE_URL=http://localhost:5173/confirm-email-change  # [PROD] your web URL

# ── Storage ──────────────────────────────────
STORAGE_PROVIDER=local_fs           # local_fs (S3/object store = future)
STORAGE_LOCAL_PATH=/var/lib/slate/uploads

# ── Single-user mode (dev convenience) ───────
SINGLE_USER_MODE=false              # [PROD] must be false (boot fails if true)
SINGLE_USER_EMAIL=

# ── Ops / observability ──────────────────────
LOG_LEVEL=INFO                      # DEBUG only during focused investigation
# [SECRET] optional error tracking
SENTRY_DSN=
# optional OTLP traces endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=
COST_GUARD_FALLBACK_WORKERS=1       # [PROD] set to your uvicorn worker count

# ── Safety kill-switches (default ON = prod-correct; flip only to debug) ─
RATE_LIMIT_ENABLED=true
COST_GUARD_ENABLED=true

# ─────────────────────────────────────────────
# Everything else uses its default in src/slate/config.py: cache TTLs, per-route
# rate limits, cost thresholds, DB pool, Ollama models, STT/OCR tuning,
# deep-recap/adaptive/embedding tuning, MFA/capture/token limits, DB pool, etc.
# Add `KEY=value` above only to override a specific one.
# ─────────────────────────────────────────────

# --- Steam import (Epic 30) ---
# Steam Web API key. Empty => the Steam account-sync feature is disabled
# (link/import endpoints return 503). Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
