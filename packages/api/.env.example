# ─────────────────────────────────────────────
# DailyLoadout API — Environment Variables
# Copy to .env and adjust as needed.
# ─────────────────────────────────────────────

# Core
APP_ENV=development
SECRET_KEY=change-me-in-prod

# Database — connection string for HOST-run dev (`make api`), pointing at the
# loopback-published Postgres. The app reads DATABASE_URL only; the DB creds
# (POSTGRES_USER/PASSWORD/DB) live in the ROOT .env — the single source of truth.
# In Docker, compose injects DATABASE_URL from those root vars using the internal
# hostname `postgres`, so you never set the connection string twice.
DATABASE_URL=postgresql+asyncpg://dailyloadout:dailyloadout@localhost:5433/dailyloadout

# Redis — connection string for HOST-run dev. Redis requires auth
# (compose: --requirepass); the app reads REDIS_URL only. REDIS_PASSWORD lives
# in the ROOT .env; in Docker, compose injects REDIS_URL from it using the
# internal hostname `redis`.
REDIS_URL=redis://:devredispassword@localhost:6380/0

# Auth cookies
# Production MUST be true (cookie only sent over HTTPS). If web and API live on
# different domains you'll use AUTH_COOKIE_SAMESITE=none, which REQUIRES Secure.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Single-user mode
SINGLE_USER_MODE=false
SINGLE_USER_EMAIL=

# LLM
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_SMART_MODEL=gemma3:12b
LLM_TIMEOUT_SECONDS=60

# Backlog Concierge (Epic 11)
CONCIERGE_PROVIDER=dummy
OLLAMA_AGENT_MODEL=qwen3:8b
CONCIERGE_MAX_TOOL_LOOPS=6

# STT
STT_PROVIDER=whisper_local
WHISPER_MODEL=base

# Agent / Deep Research Briefing
AGENT_PROVIDER=dummy
RESEARCH_PROVIDER=dummy
# Internal-only service: reach it over the compose network by name in Docker
# (http://searxng:8080); use loopback only for host-run dev.
SEARXNG_BASE_URL=http://localhost:8888
DEEP_BRIEFING_DEADLINE_SECONDS=60
DEEP_BRIEFING_MAX_REFINES=2
DEEP_BRIEFING_MAX_RESULTS=6
DEEP_BRIEFING_SCRAPE_TOP_N=2

# Storage
STORAGE_PROVIDER=local_fs
STORAGE_LOCAL_PATH=/var/lib/dailyloadout/uploads

# IGDB (optional)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# OAuth Google (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=DailyLoadout <noreply@dailyloadout.local>

# Limits
CAPTURE_MAX_AUDIO_SECONDS=60
CAPTURE_MAX_IMAGE_MB=10
CAPTURE_MAX_GAMES_PER_SHELF=12
MISSION_AUTO_CLAMP_HOURS=8

# Observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
