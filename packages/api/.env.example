# ─────────────────────────────────────────────
# DailyLoadout API — Environment Variables
# Copy to .env and adjust as needed.
#
# PRODUCTION CHECKLIST (app refuses to boot / is insecure without these):
#   APP_ENV=production · SECRET_KEY=<real> · AUTH_COOKIE_SECURE=true ·
#   TURNSTILE_SECRET=<real> · DATABASE_URL · REDIS_URL · CORS_ORIGINS
# Set for features in prod: OAuth (GOOGLE/TWITCH + OAUTH_* urls), SMTP +
#   EMAIL_VERIFICATION_BASE_URL, IGDB_CLIENT_*, real provider toggles.
# ─────────────────────────────────────────────

# ── Core ─────────────────────────────────────
APP_ENV=development                # [PROD] set to "production" (any non-dev value hardens)
SECRET_KEY=change-me-in-prod       # [PROD] MUST be a real secret (boot fails on default)
# CORS — web origins allowed to call the API. JSON list. NEVER "*".
CORS_ORIGINS=["http://localhost:3200","http://localhost:5173"]   # [PROD] your web domain(s)

# ── Database / Redis ─────────────────────────
DATABASE_URL=postgresql+asyncpg://dailyloadout:dailyloadout@localhost:5433/dailyloadout  # [PROD] real creds
REDIS_URL=redis://:devredispassword@localhost:6380/0             # [PROD] real creds (--requirepass)

# ── Caching (TTLs in seconds — defaults are fine) ─
CACHE_ENABLED=true
STATS_CACHE_TTL_SECONDS=300
BRIEFING_CACHE_TTL_SECONDS=604800
RESEARCH_CACHE_TTL_SECONDS=21600
LLM_CACHE_TTL_SECONDS=86400
REFERENCE_CACHE_TTL_SECONDS=3600

# ── Single-user mode (dev convenience; MUST be false in prod) ─
SINGLE_USER_MODE=false             # [PROD] must be false (boot fails if true)
SINGLE_USER_EMAIL=

# ── LLM ──────────────────────────────────────
LLM_PROVIDER=ollama                # ollama | dummy (cloud Bedrock/Vertex = future Epic 14)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_SMART_MODEL=gemma3:12b
OLLAMA_VISION_MODEL=qwen3-vl:4b
LLM_TIMEOUT_SECONDS=60
OLLAMA_WARMUP_MODELS=[]            # JSON list, e.g. ["qwen2.5:7b-instruct"]; only LLM_PROVIDER=ollama
OLLAMA_WARMUP_KEEP_ALIVE=30m       # '-1' pins models in RAM forever
OLLAMA_MAX_CONCURRENCY=2

# ── Agent / Deep Research Briefing (Epic 10) ─
AGENT_PROVIDER=dummy               # [PROD] langgraph | dummy
RESEARCH_PROVIDER=dummy            # [PROD] searxng | dummy
SEARXNG_BASE_URL=http://localhost:8888   # Docker: http://searxng:8080
DEEP_BRIEFING_DEADLINE_SECONDS=60
DEEP_BRIEFING_MAX_REFINES=2
DEEP_BRIEFING_MAX_RESULTS=6
DEEP_BRIEFING_SCRAPE_TOP_N=2

# ── Backlog Concierge (Epic 11) ──────────────
CONCIERGE_PROVIDER=dummy           # [PROD] langgraph | dummy
OLLAMA_AGENT_MODEL=qwen2.5:7b-instruct
CONCIERGE_AGENT_REASONING=false
CONCIERGE_MAX_TOOL_LOOPS=6
CONCIERGE_CHECKPOINTER=postgres    # postgres | memory
CONCIERGE_WRITE_TOOLS_ENABLED=true

# ── STT (voice capture) ──────────────────────
STT_PROVIDER=dummy                 # [PROD] whisper_local | dummy
WHISPER_MODEL_SIZE=base            # (was WHISPER_MODEL — that key is ignored)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── OCR / library import (Epic 14) ───────────
OCR_PROVIDER=tesseract             # tesseract | dummy
OCR_FALLBACK_PROVIDER=vision       # vision | none
OCR_CONFIDENCE_THRESHOLD=0.6
CATALOG_MATCH_MIN_SCORE=0.6
CATALOG_SHARE_THRESHOLD=5          # distinct owners to promote a manual game to shared
LIBRARY_IMPORT_MAX_CANDIDATES=40
LIBRARY_IMPORT_IMAGES_PER_DAY=10
LIBRARY_IMPORT_VISION_FALLBACKS_PER_DAY=20
LIBRARY_IMPORT_MAX_FILES=20

# ── Storage ──────────────────────────────────
STORAGE_PROVIDER=local_fs
STORAGE_LOCAL_PATH=/var/lib/dailyloadout/uploads
CAPTURE_UPLOAD_DIR=uploads/captures

# ── IGDB (game metadata — set for enrichment) ─
IGDB_CLIENT_ID=                    # [PROD-FEATURE] Twitch app client id
IGDB_CLIENT_SECRET=                # [PROD-FEATURE]
IGDB_CACHE_TTL_SECONDS=604800

# ── Social login / OAuth (Auth Code + PKCE) ──
GOOGLE_OAUTH_CLIENT_ID=            # [PROD-FEATURE]
GOOGLE_OAUTH_CLIENT_SECRET=        # [PROD-FEATURE]
TWITCH_OAUTH_CLIENT_ID=            # [PROD-FEATURE] (user-auth app; distinct from IGDB_CLIENT_*)
TWITCH_OAUTH_CLIENT_SECRET=        # [PROD-FEATURE]
# redirect_uri = {OAUTH_REDIRECT_BASE_URL}/v1/auth/oauth/{provider}/callback
# — MUST match exactly what you register with Google/Twitch.
OAUTH_REDIRECT_BASE_URL=http://localhost:8100    # [PROD] your API public URL
OAUTH_WEB_SUCCESS_URL=http://localhost:5173/oauth/callback   # [PROD] your web URL
OAUTH_WEB_ERROR_URL=http://localhost:5173/login              # [PROD] your web URL
OAUTH_STATE_TTL_SECONDS=600

# ── Email (verification delivery) ────────────
SMTP_HOST=                         # [PROD-FEATURE] empty => no email sent
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=DailyLoadout <noreply@dailyloadout.local>

# ── Registration identity hygiene (anti-abuse) ─
BLOCK_DISPOSABLE_EMAILS=true
CHECK_EMAIL_MX=true                # prod-only DNS probe, fails open
EMAIL_MX_TIMEOUT_SECONDS=3.0

# ── Email verification ───────────────────────
EMAIL_VERIFICATION_TTL_HOURS=24
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173/verify-email   # [PROD] your web URL

# ── CAPTCHA (Cloudflare Turnstile) ───────────
TURNSTILE_SECRET=                  # [PROD] REQUIRED (boot fails if empty in prod)
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ── Auth ─────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Auth refresh cookie (web cookie-mode) ────
AUTH_COOKIE_NAME=dl_refresh_token
AUTH_COOKIE_SECURE=false           # [PROD] MUST be true (boot fails if false in prod)
AUTH_COOKIE_SAMESITE=lax           # 'none' if web/api on different domains (requires Secure)
AUTH_COOKIE_PATH=/v1/auth
AUTH_COOKIE_DOMAIN=                # set if web/api share a parent domain

# ── Limits ───────────────────────────────────
CAPTURE_MAX_AUDIO_SECONDS=60
CAPTURE_MAX_IMAGE_MB=10
CAPTURE_MAX_AUDIO_MB=5
CAPTURE_MAX_GAMES_PER_SHELF=12
MISSION_AUTO_CLAMP_HOURS=24
LOADOUT_AUTO_IGNORE_HOURS=24
LOADOUT_COOLDOWN_HOURS=12

# ── Rate limiting (Redis fixed-window) ───────
RATE_LIMIT_ENABLED=true            # [PROD] keep true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_CONCIERGE_CHAT_PER_MINUTE=6
RATE_LIMIT_MISSION_BRIEFING_PER_MINUTE=4
RATE_LIMIT_LOADOUT_CREATE_PER_MINUTE=10
RATE_LIMIT_CAPTURE_SUBMIT_PER_MINUTE=15
RATE_LIMIT_LIBRARY_IMPORT_PER_MINUTE=5
RATE_LIMIT_GAME_CREATE_PER_MINUTE=20
RATE_LIMIT_LIBRARY_WRITE_PER_MINUTE=60
RATE_LIMIT_READ_PER_MINUTE=120
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Cost kill-switch (LLM spend guard) ───────
COST_GUARD_ENABLED=true            # [PROD] keep true
COST_GLOBAL_PER_MINUTE=120
COST_GLOBAL_PER_DAY=5000
COST_GLOBAL_PER_MONTH=100000
COST_USER_PER_DAY=200
COST_ALERT_THRESHOLD=0.8
COST_GUARD_DEGRADED_FALLBACK_ENABLED=true
COST_GUARD_FALLBACK_WORKERS=1      # [PROD] set to your uvicorn worker count
IGDB_USER_BUDGET_PER_DAY=300

# ── Concurrency / output caps ────────────────
STT_MAX_CONCURRENCY=2
LLM_MAX_OUTPUT_TOKENS=1024

# ── Request hardening (DoS / headers) ────────
MAX_REQUEST_BODY_BYTES=26214400    # ~25 MB
HSTS_MAX_AGE_SECONDS=63072000
DOCS_ENABLED=true                  # auto-disabled outside dev/test anyway
IGDB_CDN_ALLOWED_HOSTS=["images.igdb.com"]   # JSON list (cover_url host allowlist)

# ── DB connection pool ───────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true

# ── Observability (optional) ─────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
